// ClipForge AI — Prisma Schema
// Used if you prefer Prisma ORM (e.g., Next.js frontend with Prisma)
// Run: npx prisma migrate dev

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Plan {
  free
  pro
  creator
  agency
}

enum VideoStatus {
  downloading
  analyzing
  queued
  done
  failed
}

enum ClipStatus {
  rendering
  ready
  failed
}

enum ClipType {
  kill
  funny
  victory
  audio
  chat
}

enum Platform {
  youtube
  tiktok
  instagram
  download
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  avatarUrl String?
  passwordHash String?

  // OAuth
  googleId  String?  @unique
  twitchId  String?  @unique
  twitchToken  String?
  youtubeToken String?
  tiktokToken  String?

  // Stripe subscription
  plan                  Plan     @default(free)
  stripeCustomerId      String?
  stripeSubscriptionId  String?
  planExpiresAt         DateTime?
  clipsUsedThisMonth    Int      @default(0)

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  videos  Video[]
  clips   Clip[]
  exports Export[]
}

model Video {
  id        String      @id @default(cuid())
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  title     String
  sourceUrl String?
  game      String?
  source    String?     // twitch | youtube | upload
  durationS Int?
  fileSizeBytes BigInt?
  s3RawKey  String?

  status    VideoStatus @default(queued)
  jobId     String?
  errorMsg  String?

  eventsDetected Json?
  audioPeaks     Json?
  chatSpikes     Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clips     Clip[]
}

model Clip {
  id       String  @id @default(cuid())
  userId   String
  user     User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  videoId  String
  video    Video   @relation(fields: [videoId], references: [id], onDelete: Cascade)

  title     String
  clipType  ClipType
  startTime Float
  endTime   Float
  duration  Float

  aiScore   Float?
  game      String?
  aspect    String   @default("9:16")
  quality   String   @default("1080p")
  fps       Int      @default(60)

  status       ClipStatus @default(rendering)
  s3Key        String?
  cdnUrl       String?
  thumbnailUrl String?
  errorMsg     String?

  viewCount     Int     @default(0)
  isWatermarked Boolean @default(true)
  hasMusic      Boolean @default(false)
  hasSfx        Boolean @default(false)
  metadata      Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  exports Export[]
}

model Export {
  id      String @id @default(cuid())
  clipId  String
  clip    Clip   @relation(fields: [clipId], references: [id], onDelete: Cascade)
  userId  String
  user    User   @relation(fields: [userId], references: [id])

  platform         Platform
  platformVideoId  String?
  publishedUrl     String?
  title            String?
  description      String?
  tags             Json?
  status           String   @default("pending")
  errorMsg         String?
  viewCount        Int      @default(0)

  scheduledAt  DateTime?
  publishedAt  DateTime?
  createdAt    DateTime @default(now())
}
