# ─────────────────────────────────────────────────────────────────
# ClipForge AI — .gitignore
# ─────────────────────────────────────────────────────────────────

# ── Environment & Secrets ────────────────────────────────────────
.env
.env.local
.env.production
.env.staging
*.pem
*.key
secrets/

# ── Python ───────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
*.pyc

# ── Virtual environments ─────────────────────────────────────────
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/
.python-version

# ── AI Model weights (large binary files) ────────────────────────
*.pt
*.pth
*.onnx
*.tflite
*.pkl
*.pickle
models/

# ── Node / JS ────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.npm
.yarn-integrity
dist/
.cache/

# ── Docker volumes (local) ───────────────────────────────────────
postgres_data/
redis_data/

# ── Temp clip files ───────────────────────────────────────────────
/tmp/
clips_tmp/
*.mp4.tmp
*.partial

# ── Database / Migrations ────────────────────────────────────────
*.sqlite3
*.db
*.sql.bak

# ── Alembic ──────────────────────────────────────────────────────
# Keep env.py and script.py.mako — only ignore generated versions dir
# (versions are intentionally committed)

# ── Logs ─────────────────────────────────────────────────────────
*.log
logs/
celerybeat-schedule
celerybeat.pid

# ── IDE / Editor ─────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini

# ── macOS ─────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# ── Testing ───────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
.hypothesis/

# ── Sentry ────────────────────────────────────────────────────────
.sentryclirc

# ── Prisma ────────────────────────────────────────────────────────
prisma/.env

# ── Nginx certs (managed by Certbot) ────────────────────────────
nginx_certs/

# Portable Tools
backend/python-local/
backend/python-embed.zip
git-local/
mingit.zip
backend/get-pip.py
