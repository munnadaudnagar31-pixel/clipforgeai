# ─────────────────────────────────────────────────────────────────
# ClipForge AI — Environment Variables
# Copy to .env and fill in your values
# ─────────────────────────────────────────────────────────────────

# App
APP_ENV=production
SECRET_KEY=your-super-secret-key-at-least-32-chars-long

# Database
DATABASE_URL=postgresql+asyncpg://clipforge:password@localhost:5432/clipforge_db
POSTGRES_PASSWORD=password

# Redis
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER=redis://localhost:6379/0
CELERY_BACKEND=redis://localhost:6379/1

# AWS S3 (for video + clip storage)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=ap-south-1
S3_BUCKET_RAW=clipforge-raw-videos
S3_BUCKET_RENDERED=clipforge-rendered-clips
CLOUDFRONT_DOMAIN=d1234abcd.cloudfront.net

# JWT
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE=3600
REFRESH_TOKEN_EXPIRE=2592000

# Google OAuth (console.cloud.google.com)
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Twitch OAuth (dev.twitch.tv/console)
TWITCH_CLIENT_ID=your_twitch_client_id
TWITCH_CLIENT_SECRET=your_twitch_client_secret

# Stripe (dashboard.stripe.com)
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret
STRIPE_PRICE_PRO=price_your_pro_price_id
STRIPE_PRICE_CREATOR=price_your_creator_price_id
STRIPE_PRICE_AGENCY=price_your_agency_price_id

# YouTube Data API v3 (for Shorts publishing)
YOUTUBE_CLIENT_ID=your_youtube_client_id
YOUTUBE_CLIENT_SECRET=your_youtube_client_secret

# TikTok for Developers
TIKTOK_CLIENT_KEY=your_tiktok_client_key
TIKTOK_CLIENT_SECRET=your_tiktok_client_secret

# Sentry (optional, for error monitoring)
SENTRY_DSN=https://your_key@o123456.ingest.sentry.io/123456

# CORS (comma-separated allowed origins)
CORS_ORIGINS=["http://localhost:3000","https://clipforge.ai"]

# AI
YOLO_MODEL_PATH=models/yolov8_game_ui.pt
CV_SAMPLE_FPS=2
AUDIO_RMS_PERCENTILE=0.85
MAX_CLIPS_PER_VIDEO=10
DEFAULT_CLIP_DURATION=30
